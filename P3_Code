#define CMD_RUN_SEQUENCE 0x01
#define CMD_STOP 0x02
#define CMD_GET_TOUCH 0x03
#define CMD_SERVO2_RESET 0x04

#define RESP_BUSY 0xAA
#define RESP_STARTED 0xBB
#define RESP_TOUCH_INACTIVE 0x00
#define RESP_TOUCHED 0x01
#define RESP_NOT_TOUCHED 0x02

WebServer server(80);

byte sendCommand(uint8_t address, byte cmd) {
  Wire.beginTransmission(address);
  Wire.write(cmd);
  Wire.endTransmission();
  delay(100);
  Wire.requestFrom((uint8_t)address, (uint8_t)1);
  if (Wire.available())
    return Wire.read();
  return 0xFF;
}

void handleSequence() {
  String moduleStr = server.arg("module");
  String prevStr = server.arg("prev"); // previous module address to reset

  uint8_t address = (uint8_t)moduleStr.toInt();
  uint8_t prevAddr = (uint8_t)prevStr.toInt();

  // Reset servo2 on previous module if different
  if (prevAddr != 0 && prevAddr != address) {
    sendCommand(prevAddr, CMD_SERVO2_RESET);
  }

  byte resp = sendCommand(address, CMD_RUN_SEQUENCE);

  if (resp == RESP_BUSY)
    server.send(200, "text/plain", "BUSY");
  else if (resp == RESP_STARTED)
    server.send(200, "text/plain", "STARTED");
  else
    server.send(200, "text/plain", "ERROR");
}

void handleReset() {
  String moduleStr = server.arg("module");
  uint8_t address = (uint8_t)moduleStr.toInt();
  sendCommand(address, CMD_SERVO2_RESET);
  server.send(200, "text/plain", "RESET");
}

void handleTouch() {
  String moduleStr = server.arg("module");
  uint8_t address = (uint8_t)moduleStr.toInt();

  byte resp = sendCommand(address, CMD_GET_TOUCH);

  if (resp == RESP_TOUCH_INACTIVE)
    server.send(200, "text/plain", "inactive");
  else if (resp == RESP_TOUCHED)
    server.send(200, "text/plain", "touched");
  else if (resp == RESP_NOT_TOUCHED)
    server.send(200, "text/plain", "nottouched");
  else
    server.send(200, "text/plain", "inactive");
}

