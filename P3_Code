                if (Math.abs(itemAngle) > 90) return null;
                const distance = Math.abs(i - activeDiscIndex);
                const offset = 50 + (itemAngle / 90) * 50;
                return (
                  <text key={`disc-${i}`} fontSize={distance === 0 ? "26" : "22"} fontWeight={distance === 0 ? "bold" : "500"} fill={distance === 0 ? disc.color : "#666"} className={`transition-all ${isDraggingDisc ? 'duration-0' : 'duration-[400ms]'}`}>
                    <textPath href="#discPath" startOffset={`${offset}%`} textAnchor="middle">
                      {disc.fullName}
                    </textPath>
                  </text>
                );
              })}

              {/* YEARS TEXT */}
              {YEARS.map((year, i) => {
                const itemAngle = (i - midYearIndex) * 15 + yearRotation;
                if (Math.abs(itemAngle) > 90) return null;
                const distance = Math.abs(i - activeYearIndex);
                const offset = 50 + (itemAngle / 90) * 50;
                return (
                  <g key={`year-group-${i}`}>
                    {/* Background Mask Box - positioned to center around where text renders (above baseline at r=825) */}
                    {/* Active 26px: cap top ~y=-843, baseline y=-825, visual center ~y=-834. Mask centered at -834. */}
                    {/* Inactive 22px: cap top ~y=-840, baseline y=-825, visual center ~y=-833. Mask centered at -833. */}
                    <rect
                      transform={`rotate(${itemAngle})`}
                      x={distance === 0 ? -50 : -40}
                      y={distance === 0 ? -852 : -848}
                      width={distance === 0 ? 100 : 80}
                      height={distance === 0 ? 36 : 31}
                      rx="6"
                      fill="#f5f5f5"
                      className={`transition-all ${isDraggingYear ? 'duration-0' : 'duration-[400ms]'}`}
                    />
                    <text fontSize={distance === 0 ? "26" : "22"} fontWeight={distance === 0 ? "bold" : "500"} fill={distance === 0 ? currentDiscipline.color : "#666"} className={`transition-all ${isDraggingYear ? 'duration-0' : 'duration-[400ms]'}`}>
                      <textPath href="#yearPath" startOffset={`${offset}%`} textAnchor="middle">
                        {year}
                      </textPath>
                    </text>
                  </g>
                );
              })}

              {/* ALUMNI RING */}
              <g className="transition-transform duration-[400ms] ease-out" style={{ transform: `rotate(${alumniRotation}deg)`, transition: isDraggingAlumni ? 'none' : '' }}>
                {/* Hit area */}
                <path d={describeArc(0, 0, 950, 1250, -90, 90)} fill="rgba(0,0,0,0)" style={{ pointerEvents: 'all' }} />

                {displayAlumni.map((alumni, i) => {
                  const angle = -i * 15;
                  const currentAngle = angle + alumniRotation;
                  if (Math.abs(currentAngle) > 90) return null;

                  const isCenter = centeredAlumniIndex === i && !pendingAlumni && !selectedAlumni;
                  
                  const R_outer = isCenter ? 1250 : 1150;
                  const path = describeArc(0, 0, 950, R_outer, -7.2, 7.2);

                  const nameParts = alumni.name.split(' ');
                  const firstLine = nameParts[0];
                  const secondLine = nameParts.length > 2 ? nameParts[1] : nameParts.slice(1).join(' ');
                  const thirdLine = nameParts.length > 2 ? nameParts.slice(2).join(' ') : null;

                  return (
                    <g key={alumni.id} transform={`rotate(${angle})`} className="cursor-pointer" onClick={() => handleAlumniSelect(alumni)} style={{ pointerEvents: 'auto' }}>
                      <defs>
                        <pattern id={`pat-${alumni.id}`} patternUnits="userSpaceOnUse" x="-200" y="-1300" width="400" height="400">
                          <image href={alumni.avatar} width="400" height="400" preserveAspectRatio="xMidYMid slice" />
                        </pattern>
                      </defs>

                      {/* Base path (white background) */}
                      <path d={path} fill="#ffffff" className="transition-all duration-300 ease-out" />
                      
                      {/* Image pattern overlay */}
                      <path 
                        d={path} 
                        fill={`url(#pat-${alumni.id})`} 
                        stroke={isCenter ? "#ffffff" : "none"} 
                        strokeWidth={isCenter ? 3 : 0} 
                        className="transition-all duration-300 ease-out" 
                      />
                      
                      {/* Grey tinted overlay - fades out when active */}
                      <path 
                        d={path} 
                        fill="rgba(80,80,80,0.85)" 
                        className="transition-all duration-300 ease-out" 
                        style={{ opacity: isCenter ? 0 : 1, pointerEvents: 'none' }} 
                      />

                      {/* Curved-aligned text - fades out when active */}
                      <text
                        fill="white"
                        fontSize="13"
                        fontWeight="bold"
                        textAnchor="middle"
                        dominantBaseline="middle"
                        className="pointer-events-none uppercase tracking-[0.1em] drop-shadow-md font-sans transition-opacity duration-300"
                        style={{ opacity: isCenter ? 0 : 1 }}
                      >
                        {thirdLine ? (
                          <React.Fragment>
                            <tspan x="0" y="-1070">{firstLine}</tspan>
                            <tspan x="0" y="-1050">{secondLine}</tspan>
                            <tspan x="0" y="-1030">{thirdLine}</tspan>
                          </React.Fragment>
                        ) : secondLine ? (
                          <React.Fragment>
                            <tspan x="0" y="-1060">{firstLine}</tspan>
                            <tspan x="0" y="-1040">{secondLine}</tspan>
                          </React.Fragment>
                        ) : (
                          <tspan x="0" y="-1050">{firstLine}</tspan>
                        )}
                      </text>
                    </g>
                  );
                })}
              </g>
            </svg>
          </div>
        </React.Fragment>
      );
    }

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
)rawhtml";

void handleRoot() { server.send(200, "text/html", htmlPage); }

void setup() {
  Serial.begin(115200);
  Wire.begin(21, 22);

  if (!SPIFFS.begin(true)) {
    Serial.println("An Error has occurred while mounting SPIFFS");
  }

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("");
  Serial.print("IP: ");
  Serial.println(WiFi.localIP());

  if (MDNS.begin("esp32"))
    Serial.println("Access at http://esp32.local");

  server.on("/", handleRoot);
  server.serveStatic("/vaibhav.jpg", SPIFFS, "/vaibhav.jpg");
  server.serveStatic("/bdes.png", SPIFFS, "/bdes.png");
  server.on("/sequence", handleSequence);
  server.on("/touch", handleTouch);
  server.on("/reset", handleReset);
  server.begin();
  Serial.println("Server started");
}

void loop() { server.handleClient(); }
